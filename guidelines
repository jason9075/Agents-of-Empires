## 6. NixOS Development Setup
Since you are on NixOS, use a `shell.nix` or `flake.nix` to ensure your agent and server environments are identical.

```nix
{
  inputs.nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
  outputs = { self, nixpkgs }: {
    devShells.x86_64-linux.default = let
      pkgs = nixpkgs.legacyPackages.x86_64-linux;
    in pkgs.mkShell {
      buildInputs = with pkgs; [
        go
        gopls
        golangci-lint
        delve # For Neovim debugging
      ];
    };
  };
}
```

